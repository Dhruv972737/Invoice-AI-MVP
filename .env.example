# Frontend Environment Variables (for Netlify)
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GEMINI_API_KEY=your-gemini-api-key

# Enhanced OCR Configuration
VITE_OCR_SPACE_API_KEY=your_ocr_space_api_key_here
VITE_OCR_MIN_CONFIDENCE=75
VITE_OCR_MIN_TEXT_LENGTH=15
VITE_OCR_ENABLE_ANALYTICS=true
VITE_OCR_MAX_PROCESSING_TIME=30000
VITE_OCR_ENABLE_MULTI_LANGUAGE=true

# Backend Environment Variables (for Render)
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NODE_ENV=production
FRONTEND_URL=https://invoice-ai-mvp.netlify.app